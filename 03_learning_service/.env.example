# In the standard integrated layout, place these values in the shared project-root .env.
# When LOCAL_DATA_DIR is relative there, it resolves from the shared root.
LEARNING_SERVICE_PORT=38420
CONTENT_SERVICE_URL=http://127.0.0.1:38410
GEMINI_API_KEY=
LOCAL_DATA_DIR=./local_data

# Optional convenience settings for this implementation:
GEMINI_MODEL=gemini-2.5-flash
USE_HEURISTIC_FALLBACK=true
LEARNING_SERVICE_REQUEST_TIMEOUT_SECONDS=15
